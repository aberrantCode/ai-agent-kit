# Generated, machine-diffed files: pin to LF regardless of platform / core.autocrlf
# so regeneration diffs stay stable across Windows/macOS/Linux contributors and CI.
# (docs/requirements/canonical-repo.md §6; docs/plans/canonical-repo-plan.md T6)
CATALOG.md text eol=lf
manifest.json text eol=lf
# CHANGELOG.md is regenerated by scripts/Generate-Changelog.ps1 and machine-diffed by
# validate.ps1's changelog-staleness check. It is also regenerated on Linux by
# .github/workflows/release.yml at tag time — without this pin, the CRLF working copy
# and the LF CI rebuild disagree on every line.
CHANGELOG.md text eol=lf

# Workflow files execute `shell: bash` run blocks on Linux runners. A CRLF line ending
# inside one surfaces as `$'\r': command not found` at runtime — the YAML parses fine,
# so this fails only when the release actually runs.
.github/workflows/* text eol=lf

# Release-automation templates shipped inside the github:release-init skill bundle.
# Same hazard as above, one step removed: nothing here executes them, so a CRLF
# corruption would only surface in whatever downstream repo /release-init provisions.
claude/skills/github/sub-skills/release-init/templates/* text eol=lf

# git hooks: must stay LF regardless of platform / core.autocrlf. Git invokes hooks
# via a shell using the file's shebang line (docs/requirements/canonical-repo.md §6;
# scripts/validate.ps1, T8) — a CRLF shebang line is a broken interpreter path on
# POSIX shells, including Git for Windows' bundled sh.exe.
scripts/git-hooks/* text eol=lf

# Deployable git-hook templates shipped inside the github:repo-init skill bundle. Same
# CRLF-shebang hazard as above, but one step removed: nothing in THIS repo executes them,
# so a CRLF corruption here would only surface in whatever downstream repo /init-repo
# deploys them into. Pin them at the source.
claude/skills/github/sub-skills/repo-init/templates/hooks/* text eol=lf
codex/skills/github/sub-skills/repo-init/templates/hooks/*  text eol=lf
